<https://workflowhub.eu/workflows/110?version=12> a ns1:ComputationalWorkflow,
        ns1:SoftwareSourceCode ;
    dcterms:conformsTo <https://bioschemas.org/profiles/ComputationalWorkflow/1.0-RELEASE/> ;
    ns1:contributor <https://workflowhub.eu/people/112> ;
    ns1:creator <https://workflowhub.eu/people/222> ;
    ns1:dateCreated "2026-05-14T02:01:42Z"^^ns1:Date ;
    ns1:dateModified "2026-05-14T02:01:42Z"^^ns1:Date ;
    ns1:description "The workflow for Illumina-sequenced ARTIC data builds on the RNASeq workflow for paired-end data using the same steps for mapping and variant calling, but adds extra logic for trimming ARTIC primer sequences off reads with the ivar package. In addition, this workflow uses ivar also to identify amplicons affected by ARTIC primer-binding site mutations and tries to exclude reads derived from such tainted amplicons when calculating allele-frequencies of other variants." ;
    ns1:input <https://workflowhub.eu/workflows/110#sars_cov_2_pe_illumina_artic_variant_calling_covid_19_pe_artic_illumina-inputs-%23main/ARTIC%20primer%20BED>,
        <https://workflowhub.eu/workflows/110#sars_cov_2_pe_illumina_artic_variant_calling_covid_19_pe_artic_illumina-inputs-%23main/ARTIC%20primers%20to%20amplicon%20assignments>,
        <https://workflowhub.eu/workflows/110#sars_cov_2_pe_illumina_artic_variant_calling_covid_19_pe_artic_illumina-inputs-%23main/Minimum%20DP%20required%20after%20amplicon%20bias%20correction>,
