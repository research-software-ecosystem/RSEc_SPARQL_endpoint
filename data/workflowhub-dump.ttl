    ns1:dateModified "2026-05-13T13:04:59Z"^^ns1:Date ;
    ns1:description """Workflow for NonSpliced RNAseq data with multiple aligners.

Steps:  
    - workflow_quality.cwl:
        - FastQC (control)
        - fastp (trimming)
    - bowtie2 (read mapping)
    - sam_to_sorted-bam
    - featurecounts (transcript read counts)
    - kallisto (transcript [pseudo]counts)
""" ;
    ns1:image <https://workflowhub.eu/workflows/94/diagram?version=1> ;
    ns1:input <https://workflowhub.eu/workflows/77#nonspliced_rnaseq_workflow-inputs-bowtie2-indexfolder>,
        <https://workflowhub.eu/workflows/77#nonspliced_rnaseq_workflow-inputs-filter_rrna>,
        <https://workflowhub.eu/workflows/77#nonspliced_rnaseq_workflow-inputs-forward_reads>,
