    ns1:input <https://workflowhub.eu/workflows/75#indices_builder_from_gbol_rdf__ttl_-inputs-genomeSAindexNbases>,
        <https://workflowhub.eu/workflows/75#indices_builder_from_gbol_rdf__ttl_-inputs-inputFile>,
        <https://workflowhub.eu/workflows/75#indices_builder_from_gbol_rdf__ttl_-inputs-memory>,
        <https://workflowhub.eu/workflows/75#indices_builder_from_gbol_rdf__ttl_-inputs-run_star>,
        <https://workflowhub.eu/workflows/75#indices_builder_from_gbol_rdf__ttl_-inputs-threads> ;
    ns1:keywords "Alignment" ;
    ns1:license <https://spdx.org/licenses/CC0-1.0> ;
    ns1:name "Indices builder from GBOL RDF (TTL)" ;
    ns1:output <https://workflowhub.eu/workflows/75#indices_builder_from_gbol_rdf__ttl_-outputs-STAR>,
        <https://workflowhub.eu/workflows/75#indices_builder_from_gbol_rdf__ttl_-outputs-bowtie2>,
        <https://workflowhub.eu/workflows/75#indices_builder_from_gbol_rdf__ttl_-outputs-genomefasta>,
