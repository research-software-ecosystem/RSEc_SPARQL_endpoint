galaxytool:nanocompore a schema:SoftwareApplication ;
    schema:applicationSubCategory edam:topic_0659,
        edam:topic_0749,
        edam:topic_3170,
        edam:topic_3308,
        edam:topic_3512 ;
    schema:description "Nanocompore compares 2 ONT nanopore direct RNA sequencing datasets from different experimental conditions expected to have a significant impact on RNA modifications. It is recommended to have at least 2 replicates per condition. For example one can use a control condition with a significantly reduced number of modifications such as a cell line for which a modification writing enzyme was knocked-down or knocked-out. Alternatively, on a smaller scale transcripts of interests could be synthesized in-vitro." ;
    schema:featureList edam:operation_0428,
        edam:operation_3196,
        edam:operation_3472 ;
    schema:identifier biotools:Nanocompore,
        bioconda:nanocompore ;
    schema:isPartOf <https://usegalaxy.eu>,
        <https://usegalaxy.eu/published/workflow?id=778923dd04996e07>,
        <https://usegalaxy.eu/published/workflow?id=77db45ad90b4033d> ;
    schema:keywords "Sequence Analysis" ;
    schema:name "nanocompore" ;
    schema:softwareVersion "1.0.0rc3.post2" ;
    schema:url "https://nanocompore.rna.rocks/" .

