galaxytool:metaeuk a schema:SoftwareApplication ;
    schema:applicationSubCategory edam:topic_0623,
        edam:topic_3174 ;
    schema:description "MetaEuk is a modular toolkit designed for large-scale gene discovery andannotation in eukaryotic metagenomic contigs. Metaeuk combines the fast andsensitive homology search capabilities of MMseqs2 with a dynamic programmingprocedure to recover optimal exons sets. It reduces redundancies in multiplediscoveries of the same gene and resolves conflicting gene predictions onthe same strand. " ;
    schema:featureList edam:operation_3663 ;
    schema:identifier biotools:MetaEuk,
        bioconda:metaeuk ;
    schema:isPartOf <https://usegalaxy.eu>,
        <https://usegalaxy.eu/published/workflow?id=9b9e1e28f3683f92> ;
    schema:keywords "Genome annotation",
        "Sequence Analysis" ;
    schema:name "metaeuk" ;
    schema:softwareVersion "@TOOL_VERSION@" ;
    schema:url "https://github.com/soedinglab/metaeuk" .

