galaxytool:kallisto a schema:SoftwareApplication ;
    schema:applicationSubCategory edam:topic_0203,
        edam:topic_3170,
        edam:topic_3308 ;
    schema:description "kallisto is a program for quantifying abundances of transcripts from RNA-Seqdata, or more generally of target sequences using high-throughput sequencingreads. It is based on the novel idea of pseudoalignment for rapidlydetermining the compatibility of reads with targets, without the need foralignment." ;
    schema:featureList edam:operation_0314 ;
    schema:identifier biotools:kallisto,
        bioconda:kallisto ;
    schema:isPartOf <https://usegalaxy.eu>,
