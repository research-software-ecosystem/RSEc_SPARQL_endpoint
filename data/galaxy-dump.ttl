galaxytool:delly a schema:SoftwareApplication ;
    schema:applicationSubCategory edam:topic_0091,
        edam:topic_0199,
        edam:topic_0622,
        edam:topic_0634,
        edam:topic_3168,
        edam:topic_3325,
        edam:topic_3796 ;
    schema:description "Delly is an integrated structural variant (SV) prediction method that can discover, genotype and visualize deletions, tandem duplications, inversions and translocations at single-nucleotide resolution in short-read massively parallel sequencing data. It uses paired-ends, split-reads and read-depth to sensitively and accurately delineate genomic rearrangements throughout the genome." ;
    schema:featureList edam:operation_0452,
        edam:operation_3196,
        edam:operation_3197,
        edam:operation_3227,
        edam:operation_3228 ;
    schema:identifier biotools:delly2,
        bioconda:delly ;
    schema:keywords "Variant Analysis" ;
    schema:name "delly" ;
    schema:softwareVersion "0.9.1" ;
    schema:url "https://github.com/dellytools/delly" .

