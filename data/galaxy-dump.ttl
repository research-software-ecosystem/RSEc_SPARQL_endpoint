galaxytool:bbtools a schema1:SoftwareApplication ;
    schema1:applicationSubCategory edam:topic_3168,
        edam:topic_3170,
        edam:topic_3174,
        edam:topic_3293,
        edam:topic_3320,
        edam:topic_3673 ;
    schema1:description "BBTools is a suite of fast, multithreaded bioinformatics tools designed for analysis of DNA and RNA sequence data.BBTools can handle common sequencing file formats such as fastq, fasta, sam, scarf, fasta+qual, compressed or raw,with autodetection of quality encoding and interleaving. It is written in Java and works on any platform supportingJava, including Linux, MacOS, and Microsoft Windows and Linux; there are no dependencies other than Java (version7 or higher). Program descriptions and options are shown when running the shell scripts with no parameters." ;
    schema1:featureList edam:data_0863,
        edam:operation_0292,
        edam:operation_3187,
        edam:operation_3192,
        edam:operation_3198,
        edam:operation_3680,
        edam:operation_3798,
        edam:topic_0182 ;
    schema1:identifier biotools:bbmap,
        bioconda:bbmap ;
    schema1:isPartOf "https://usegalaxy.eu/published/workflow?id=d967194ca51ff11e",
        "https://usegalaxy.org.au/published/workflow?id=25f65a29ce3c3ee0",
        "workflowhub:407?version=1",
        "workflowhub:519?version=1" ;
    schema1:keywords "Sequence Analysis" ;
    schema1:name "bbtools" ;
    schema1:softwareVersion "39.08" ;
    schema1:url "https://jgi.doe.gov/data-and-tools/bbtools/" .

